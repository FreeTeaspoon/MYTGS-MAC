PRODUCT_BUNDLE_IDENTIFIER = com.freeteaspoon.mytgs

MYTGS_DEVELOPMENT_TEAM =
MYTGS_CODE_SIGN_IDENTITY = Developer ID Application
MYTGS_NOTARY_PROFILE = MYTGS-notarytool
MYTGS_SPARKLE_FEED_URL = https:/$()/freeteaspoon.github.io/MYTGS-MAC/appcast.xml
MYTGS_SPARKLE_PUBLIC_ED_KEY = +Gt7fCiZPmAL9OtGkc2lp8OpFT8I5TzLNAX0x3n/AMU=

#include? "Signing.local.xcconfig"

CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = $(MYTGS_CODE_SIGN_IDENTITY)
DEVELOPMENT_TEAM = $(MYTGS_DEVELOPMENT_TEAM)
ENABLE_HARDENED_RUNTIME = YES
OTHER_CODE_SIGN_FLAGS = --timestamp
INFOPLIST_KEY_SUFeedURL = $(MYTGS_SPARKLE_FEED_URL)
INFOPLIST_KEY_SUPublicEDKey = $(MYTGS_SPARKLE_PUBLIC_ED_KEY)
